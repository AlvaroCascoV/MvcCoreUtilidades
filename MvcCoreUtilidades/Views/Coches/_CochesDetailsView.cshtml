@model Coche

<h1>Detalles Ajax view</h1>

@if(Model == null)
{
    <h2 style="color:red">Noo existe el coche</h2>
}
else
{
    <div class="card" style="width:18rem">
        <img src="@Model.Imagen" class="card-img-top" alt="@Model.Marca @Model.Modelo" />
        <div class="card-body">
            <h5 class="card-title">@Model.Marca @Model.Modelo</h5>
        </div>
    </div>
}